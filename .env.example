# ElderCare-EQ Lite runner 配置（cp .env.example .env 后填写）
# 协议一律 OpenAI 兼容 /v1/chat/completions；预设示例见下

# ── 被测（你的 AI 健康管家）──
CANDIDATE_BASE_URL=https://your-agent-host/v1
CANDIDATE_API_KEY=sk-...
CANDIDATE_MODEL=your-agent-model

# ── 判官（务必与被测底座异厂；同族自评实测约 2× 偏宽）──
# OpenRouter:  https://openrouter.ai/api/v1
# DeepSeek:    https://api.deepseek.com/v1
# SiliconFlow: https://api.siliconflow.cn/v1
# Gemini:      https://generativelanguage.googleapis.com/v1beta/openai
JUDGE_BASE_URL=https://openrouter.ai/api/v1
JUDGE_API_KEY=sk-or-...
JUDGE_MODEL=anthropic/claude-sonnet-4.5
